ENV=local
DEBUG=true

APP_NAME=Conversational CV Builder
API_PREFIX=/api/v1

OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4000
OPENAI_VERIFY_SSL=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cv_builder
DB_USER=root
DB_PASSWORD=replace-with-db-password
SEED_AUTH_PASSWORD=replace-with-strong-password

STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/storage

TEMPLATE_BASE_PATH=./src/templates
DEFAULT_TEMPLATE=standard_nttdata
QUESTIONNAIRE_PATH=./config/questionnaire

ENABLE_RAG=true
ENABLE_VOICE=true
ENABLE_REVIEW=false
ENABLE_RBAC=true
# Use MySQL-backed sessions for durable persistence during development and testing.
# If you want ephemeral in-memory sessions instead, set SESSION_REPOSITORY_BACKEND=memory.
SESSION_REPOSITORY_BACKEND=mysql
SESSION_FILE_STORE_PATH=./data/storage/sessions

LOG_LEVEL=INFO
SECRET_KEY=replace-with-a-long-random-secret
TOKEN_EXPIRE_MINUTES=60

SPEECH_PROVIDER=whisper
WHISPER_MODEL=whisper-1
AZURE_SPEECH_LANGUAGE=en-US